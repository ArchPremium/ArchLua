-- BUTTON CREATOR
local function createButton(text, order)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -20, 0, 50)
	btn.Position = UDim2.new(0, 10, 0, 60 + (order * 60))
	btn.Text = text
	btn.BackgroundColor3 = Color3.fromRGB(25, 5, 45)
	btn.TextColor3 = Color3.fromRGB(230, 200, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.Parent = mainFrame
	
	local corner = Instance.new("UICorner")
	corner.Parent = btn
	
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(60, 0, 120)
		}):Play()
	end)
	
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(25, 5, 45)
		}):Play()
	end)
	
	btn.MouseButton1Click:Connect(function()
		print("[ArchPremium] " .. text .. " clicked")
	end)
end

createButton("Freeze Trade", 1)
createButton("Auto Accept", 2)
